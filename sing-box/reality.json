{
    "log": {
        "disabled": false,
        "level": "error",
        "timestamp": true
    },
    "inbounds": [
        {
            "type": "hysteria2",
            "tag": "hy2-in",
            "listen": "::",
            "listen_port": 443,
            "users": [
                {
                    "name": "user_hysteria2",
                    "password": "${UUID}"
                }
            ],
            "tls": {
                "enabled": true,
                "server_name": "${DOMAIN}",
                "alpn": [
                    "h3"
                ],
                "acme": {
                    "domain": [
                        "${DOMAIN}"
                    ],
                    "provider": "letsencrypt",
                    "dns01_challenge": {
                        "provider": "cloudflare",
                        "api_token": "${CF_Token}"
                    }
                }
            }
        },
        {
            "type": "tuic",
            "tag": "tuic-in",
            "listen": "::",
            "listen_port": 8443,
            "users": [
                {
                    "name": "user_tuic",
                    "uuid": "${UUID}",
                    "password": "${UUID}"
                }
            ],
            "tls": {
                "enabled": true,
                "server_name": "${DOMAIN}",
                "alpn": [
                    "h3"
                ],
                "acme": {
                    "domain": [
                        "${DOMAIN}"
                    ],
                    "provider": "letsencrypt",
                    "dns01_challenge": {
                        "provider": "cloudflare",
                        "api_token": "${CF_Token}"
                    }
                }
            }
        },
        {
            "type": "anytls",
            "tag": "anytls-in",
            "listen": "::",
            "listen_port": 8443,
            "users": [
                {
                    "name": "user_anytls",
                    "password": "${UUID}"
                }
            ],
            "tls": {
                "enabled": true,
                "server_name": "${DOMAIN}",
                "acme": {
                    "domain": [
                        "${DOMAIN}"
                    ],
                    "provider": "letsencrypt",
                    "dns01_challenge": {
                        "provider": "cloudflare",
                        "api_token": "${CF_Token}"
                    }
                }
            }
        },
        {
            "type": "vless",
            "tag": "reality-in",
            "listen": "::",
            "listen_port": 443,
            "users": [
                {
                    "name": "user_reality",
                    "uuid": "${UUID}",
                    "flow": "xtls-rprx-vision"
                }
            ],
            "tls": {
                "enabled": true,
                "server_name": "cdn-dynmedia-1.microsoft.com",
                "reality": {
                    "enabled": true,
                    "handshake": {
                        "server": "cdn-dynmedia-1.microsoft.com",
                        "server_port": 443
                    },
                    "private_key": "${PRIKEY}",
                    "short_id": [
                        "${SID}"
                    ]
                }
            }
        }
    ],
    "outbounds": [
        {
            "type": "direct",
            "tag": "direct-out"
        }
    ]
}
