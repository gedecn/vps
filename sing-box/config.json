{
    "log": {
        "disabled": false,
        "level": "error",
        "timestamp": true
    },
    "inbounds": [
        {
            "type": "hysteria2",
            "tag": "hy2-in",
            "listen": "::",
            "listen_port": 443,
            "users": [
                {
                    "name": "user_hysteria2",
                    "password": "${UUID}"
                }
            ],
            "tls": {
                "enabled": true,
                "certificate_path": "/etc/cert/${DOMAIN}.pem",
                "key_path": "/etc/cert/${DOMAIN}.key",
                "alpn": [
                    "h3"
                ]
            },
            "masquerade": "https://bing.com"
        },
        {
            "type": "vless",
            "tag": "reality-in",
            "listen": "::",
            "listen_port": 443,
            "users": [
                {
                    "name": "user_reality",
                    "uuid": "${UUID}",
                    "flow": "xtls-rprx-vision"
                }
            ],
            "tls": {
                "enabled": true,
                "server_name": "cdn-dynmedia-1.microsoft.com",
                "reality": {
                    "enabled": true,
                    "handshake": {
                        "server": "cdn-dynmedia-1.microsoft.com",
                        "server_port": 443
                    },
                    "private_key": "${PRIKEY}",
                    "short_id": [
                        "${SID}"
                    ]
                }
            }
        }
    ],
    "outbounds": [
        {
            "type": "direct",
            "tag": "direct-out"
        }
    ]
}
